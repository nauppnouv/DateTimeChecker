{
  "name": "datetimechecker-tests",
  "version": "1.0.0",
  "description": "Playwright tests for Date Time Checker",
  "main": "index.js",
  "scripts": {
    "test:unit": "mvn test",
    "test:e2e": "playwright test tests/e2e/datetime.spec.ts",
    "test:api": "playwright test tests/api",
    "test:mobile": "maestro test tests/mobile/datetime-flow.yaml",
    "test:widget": "cd flutter_app && flutter test",
    "test:perf": "k6 run tests/performance/load-test.js",
    "test:visual": "playwright test tests/e2e/visual",
    "test:visual:update": "playwright test tests/e2e/visual --update-snapshots",
    "test:ai": "playwright test tests/ai",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e && npm run test:widget && npm run test:visual && npm run test:ai",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.9.0"
  }
}
